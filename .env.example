# --- Telegram ---
BOT_TOKEN=PASTE_TELEGRAM_BOT_TOKEN_HERE
ADMIN_TELEGRAM_ID=123456789

# --- HTTPS API server (webhooks + patterns) ---
API_HOST=0.0.0.0
API_PORT=444

# Сертификаты будут примонтированы в контейнер
API_SSL_CERT_FILE=/certs/fullchain.pem
API_SSL_KEY_FILE=/certs/privkey.pem

# Пути
WEBHOOK_PATH=/api/webhook
PATTERNS_PATH=/api/patterns
HEALTH_PATH=/health

# --- Auth for inbound requests ---
# Watchdog будет слать Authorization: Bearer <...>
WEBHOOK_TOKEN_IN=CHANGE_ME_WEBHOOK
PATTERNS_TOKEN_IN=CHANGE_ME_PATTERNS

# --- Patterns storage ---
PATTERNS_FILE=/data/patterns.json
PATTERNS_CACHE_SECONDS=5

# --- Webhook processing queue ---
WEBHOOK_QUEUE_SIZE=256
WEBHOOK_WORKERS=1

# --- Optional: panel integration (заготовка) ---
PANEL_BASE_URL=
PANEL_API_TOKEN=
PANEL_TIMEOUT_SECONDS=5
# Шаблоны путей (подстрой под свою панель)
PANEL_USER_INFO_PATH=/api/users/{user_id}
PANEL_FULL_USER_INFO_PATH=/api/users/by-telegram-id/{telegram_id}
PANEL_BAN_PATH=/api/users/{uuid}/ban

# --- Logging ---
LOG_LEVEL=INFO